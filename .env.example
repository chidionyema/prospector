# Prospector environment configuration
# Copy this file to .env and fill in your actual API keys.
# .env is gitignored and should NEVER be committed to version control.

# Gemini API key (required for live retrieval)
GEMINI_API_KEY=your-gemini-key-here

# Exa search API key (STRONGLY recommended — the fast/cheap PRIMARY grounding path.
# Exa is an HTTP search API: sub-second, no LLM tokens burned. It sits first in the
# retrieval chain so the moat does NOT fall back to the slow (~55s) / token-heavy
# (~25k tok/search) Gemini-CLI grounding. Get a key at https://exa.ai .)
EXA_API_KEY=your-exa-key-here

# Brave search API key (optional secondary fast/cheap HTTP search; after Exa.)
# BRAVE_API_KEY=your-brave-key-here

# Claude API key (optional; only if operator is set to "claude" in config.yaml)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# DeepSeek API key (optional; enables DeepSeek for non-critical calls —
# $0.27/M input, $1.10/M output.  Routed to prescreen/score/content.
# The moat (verdict + adversarial) always stays Claude/Gemini regardless.)
# DEEPSEEK_API_KEY=your-deepseek-key-here

# MiniMax API key (optional; enables MiniMax for generation — $0.30/M input.
# Routed to generation + non-critical calls.  Moat always stays Claude/Gemini.)
# MINIMAX_API_KEY=your-minimax-key-here

# Optional: override config.yaml operator via env var
# PROSPECTOR_OPERATOR=claude

# Optional: override model choice
# PROSPECTOR_MODEL=claude

# Optional: enable debug logging
# DEBUG=1

# NOTE: NEVER commit real API keys to version control.
# If you accidentally paste a secret here, rotate it immediately.
# See https://docs.anthropic.com/en/docs/build-a-system-with-agents/claude-api
# for latest API key management best practices.

# ============================================================
# Store / Commerce Configuration
# ============================================================

# Store API URL (the .NET backend). Default http://localhost:5291
# STORE_API_URL=http://localhost:5291

# Internal API key for the engine-to-store publish endpoint.
# Must match Store:InternalApiKey in the .NET appsettings.
# STORE_INTERNAL_API_KEY=prospector-dev-key

# The store's public URL (used for CORS and email magic links).
# STORE_PUBLIC_URL=http://localhost:5291

# CORS-allowed origin (the Next.js storefront).
# STORE_ALLOWED_ORIGIN=http://localhost:3000

# Active payment provider: "paddle" or "stripe". Default paddle.
# PAYMENTS_ACTIVE_PROVIDER=paddle

# Paddle API key and environment (sandbox or live).
# PADDLE_API_KEY=your-paddle-api-key
# PADDLE_ENVIRONMENT=sandbox

# Stripe API key (if using Stripe as the payment provider).
# STRIPE_API_KEY=your-stripe-key

# ============================================================
# Content Storage (R2 / S3-compatible)
# ============================================================

# Cloudflare R2 credentials. When any are missing, uploads gracefully
# degrade and packs are registered UNLISTED (never sold undeliverably).
# R2_ACCOUNT_ID=your-r2-account-id
# R2_ACCESS_KEY_ID=your-r2-access-key
# R2_SECRET_ACCESS_KEY=your-r2-secret-key
# R2_BUCKET=prospector-packs
