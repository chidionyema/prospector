# Prospector environment configuration
# Copy this file to .env and fill in your actual API keys.
# .env is gitignored and should NEVER be committed to version control.

# Gemini API key (required for live retrieval)
GEMINI_API_KEY=your-gemini-key-here

# Claude API key (optional; only if operator is set to "claude" in config.yaml)
# ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional: override config.yaml operator via env var
# PROSPECTOR_OPERATOR=claude

# Optional: override model choice
# PROSPECTOR_MODEL=claude

# Optional: enable debug logging
# DEBUG=1

# NOTE: NEVER commit real API keys to version control.
# If you accidentally paste a secret here, rotate it immediately.
# See https://docs.anthropic.com/en/docs/build-a-system-with-agents/claude-api
# for latest API key management best practices.
