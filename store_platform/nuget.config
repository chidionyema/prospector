<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Crux kernel packages, VENDORED into the repo (store_platform/local-feed) so a clean
         checkout / CI builds with no sibling keystone repo and no GitHub token. The path is
         relative to this nuget.config. Refresh the feed from keystone with:
           dotnet pack ~/Documents/code/keystone -o ~/Documents/code/keystone/nupkg
           cp ~/Documents/code/keystone/nupkg/Crux.*.nupkg store_platform/local-feed/
         To move to a hosted feed instead, swap this source for GitHub Packages:
           <add key="crux-github" value="https://nuget.pkg.github.com/chidionyema/index.json" />
         See PLATFORM_KERNEL_PLAN.md §4 and DEPLOYMENT.md. -->
    <add key="crux-local" value="local-feed" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="crux-local">
      <package pattern="Crux.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
