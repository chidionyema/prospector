<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Crux kernel packages. For local development, the feed is built from
         ~/Documents/code/keystone via `dotnet pack -o nupkg/`.
         For CI/production, switch to GitHub Packages:
         <add key="crux-github" value="https://nuget.pkg.github.com/chidionyema/index.json" />
         See PLATFORM_KERNEL_PLAN.md §4 and DEPLOYMENT.md. -->
    <add key="crux-local" value="/Users/chidionyema/Documents/code/keystone/nupkg" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="crux-local">
      <package pattern="Crux.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
