{
  "name": "store-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "conformance": "node scripts/check-conformance.mjs",
    "verify": "npm run typecheck && npm run lint && npm run conformance",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:coreloop": "playwright test --project=coreloop"
  },
  "dependencies": {
    "@daily-co/daily-js": "^0.90.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.7.0",
    "geist": "^1.7.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.5.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
