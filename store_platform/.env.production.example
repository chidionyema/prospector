# Store.Api — PRODUCTION environment (live money path).
#
# Copy to store_platform/.env.production and fill in the real values, then run:
#   bash store_platform/scripts/go_live.sh
# .env.production is gitignored. NEVER commit real keys. Rotate immediately if leaked.
#
# Every key below is REQUIRED for a live Stripe cutover. MoneyRailConfigGate
# (a fail-closed boot gate) refuses to start the API if any is missing or left at a
# dev placeholder, so a misconfigured deploy fails loudly instead of taking money it
# cannot fulfil. go_live.sh validates the same rules before it boots anything.

# --- Environment ---
ASPNETCORE_ENVIRONMENT=Production

# SQLite catalogue + orders db. Use an absolute path on a persistent volume.
ConnectionStrings__DefaultConnection=Data Source=/var/lib/store/store.db

# --- Stripe (LIVE) ---
# Secret key from the Stripe dashboard (LIVE mode). Must start with sk_live_.
Stripe__ApiKey=sk_live_REPLACE_ME
# Signing secret of the LIVE webhook endpoint you register at
# https://dashboard.stripe.com/webhooks (events: checkout.session.completed,
# charge.refunded, charge.dispute.created). Must start with whsec_.
Stripe__WebhookSecret=whsec_REPLACE_ME
# Active provider. Set to stripe to route the money path through Stripe.
payments__active_provider=stripe

# --- Engine -> Store publish auth (must NOT be the dev placeholders) ---
# Strong random secrets, e.g. `openssl rand -hex 32`. The engine uses the SAME
# values to authenticate to /internal/catalog and /entitlements.
Store__InternalApiKey=REPLACE_ME_openssl_rand_hex_32
Store__EntitlementsApiKey=REPLACE_ME_openssl_rand_hex_32

# --- Public URLs / CORS ---
# The storefront origin allowed to call this API (no trailing slash).
STORE_ALLOWED_ORIGIN=https://your-storefront-domain
# This API's public base URL (used to build Stripe checkout return links).
STORE_PUBLIC_URL=https://your-api-domain

# --- Content storage (Cloudflare R2) ---
# Without these, packs register UNLISTED (never sold undeliverably). Required to deliver.
R2_ACCOUNT_ID=REPLACE_ME
R2_ACCESS_KEY_ID=REPLACE_ME
R2_SECRET_ACCESS_KEY=REPLACE_ME
R2_BUCKET=prospector-packs
